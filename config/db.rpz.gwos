; GWOS — Response Policy Zone (RPZ)
; Gerado automaticamente pelo script aplicar_bind9_rpz.sh
; NÃO editar manualmente — será sobrescrito pelo painel.

$TTL 60
@ IN SOA localhost. root.localhost. (
    2024010101 ; serial
    3600       ; refresh
    900        ; retry
    604800     ; expire
    60         ; minimum TTL
)
    IN NS localhost.

; Entradas de bloqueio serão inseridas aqui pelo painel GWOS
